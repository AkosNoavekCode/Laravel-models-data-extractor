{
	"name": "akosnoavek/models-data-extractor",
	"description": "Extract information from models or other data structures based on a given schema to the formats you prefer",
	"type": "library",
	"license": "MIT",
	"require": {
		"laravel/framework": "^12.0",
		"php": "^8.2",
		"openspout/openspout": "^4.23"
	},
	"autoload": {
		"psr-4": {
			"AkosNoavek\\DataExtractor\\": "src/",
			"tests\\": "tests/"
		},
		"files": [
			"src/helpers.php"
		]
	},
	"authors": [
		{
			"name": "g.mannai",
			"email": "g.mannai@invisiblefarm.com"
		}
	],
	"minimum-stability": "dev",
	"require-dev": {
		"pestphp/pest": "4.x-dev",
		"orchestra/testbench": "10.x-dev",
		"phpoffice/phpspreadsheet": "*"
	},
	"scripts-aliases": {
		"test": [
			"./vendor/bin/pest"
		]
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"AkosNoavek\\DataExtractor\\Support\\ServiceProvider"
			],
			"aliases": {
				"DataExtractor": "AkosNoavek\\DataExtractor\\Facades\\DataExtractor"
			}
		}
	}
}
