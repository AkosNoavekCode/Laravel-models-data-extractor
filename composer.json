{
	"name": "akosnoavek/models-data-extractor",
	"description": "Extract your models data based on a given json schema to the formats you prefer",
	"type": "library",
	"require": {
		"laravel/laravel": "12",
		"php": "^8.2"
	},
	"autoload": {
		"psr-4": {
			"AkosNoavek\\DataExtractor\\": "src/",
			"tests\\": "tests/"
		},
		"files": ["src/helpers.php"]
	},
	"authors": [
		{
			"name": "g.mannai",
			"email": "g.mannai@invisiblefarm.com"
		}
	],
	"laravel": {
		"providers": ["Akosnoavek\\DataExtractor\\Support\\ServiceProvider"],
		"aliases": {
			"DataExtractor": "Akosnoavek\\DataExtractor\\Facades\\DataExtractor"
		}
	},
	"minimum-stability": "dev",
	"require-dev": {
		"pestphp/pest": "4.x-dev",
		"orchestra/testbench": "10.x-dev"
	},
	"scripts-aliases": {
		"test": ["./vendor/bin/pest"]
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	}
}
